{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/k0sproject/rig/v2/win-rm",
  "$ref": "#/$defs/WinRM",
  "$defs": {
    "OptionArguments": {
      "type": "object"
    },
    "SSH": {
      "properties": {
        "address": {
          "anyOf": [
            {
              "type": "string",
              "format": "hostname"
            },
            {
              "type": "string",
              "format": "ipv4"
            },
            {
              "type": "string",
              "format": "ipv6"
            }
          ],
          "description": "Address of the remote host (IP or hostname)"
        },
        "user": {
          "type": "string",
          "minLength": 1,
          "description": "User to log in as",
          "default": "root"
        },
        "port": {
          "type": "integer",
          "maximum": 65535,
          "minimum": 1,
          "description": "SSH port (default 22)",
          "default": 22
        },
        "keyPath": {
          "type": "string",
          "description": "Path to SSH private key"
        },
        "bastion": {
          "$ref": "#/$defs/SSH",
          "description": "Optional bastion host"
        },
        "options": {
          "$ref": "#/$defs/OptionArguments",
          "description": "Additional SSH options as ssh_config key-value pairs"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "address"
      ]
    },
    "WinRM": {
      "anyOf": [
        {
          "required": [
            "user",
            "password"
          ]
        },
        {
          "required": [
            "certPath",
            "keyPath"
          ]
        }
      ],
      "properties": {
        "address": {
          "anyOf": [
            {
              "type": "string",
              "format": "hostname"
            },
            {
              "type": "string",
              "format": "ipv4"
            },
            {
              "type": "string",
              "format": "ipv6"
            }
          ],
          "description": "Address of the remote host"
        },
        "user": {
          "type": "string",
          "minLength": 3,
          "description": "User to authenticate as",
          "default": "Administrator"
        },
        "port": {
          "type": "integer",
          "maximum": 65535,
          "minimum": 1,
          "description": "WinRM port (default 5985; 5986 when useHTTPS is true)"
        },
        "password": {
          "type": "string",
          "minLength": 1,
          "description": "Password for WinRM authentication"
        },
        "useHTTPS": {
          "type": "boolean",
          "description": "Use HTTPS for WinRM",
          "default": false
        },
        "insecure": {
          "type": "boolean",
          "description": "Accept invalid TLS certificates",
          "default": false
        },
        "useNTLM": {
          "type": "boolean",
          "description": "Use NTLM authentication",
          "default": false
        },
        "caCertPath": {
          "type": "string",
          "description": "Path to CA certificate"
        },
        "certPath": {
          "type": "string",
          "minLength": 1,
          "description": "Path to client certificate"
        },
        "keyPath": {
          "type": "string",
          "minLength": 1,
          "description": "Path to client key"
        },
        "tlsServerName": {
          "anyOf": [
            {
              "type": "string",
              "format": "hostname"
            },
            {
              "type": "string",
              "format": "ipv4"
            },
            {
              "type": "string",
              "format": "ipv6"
            }
          ],
          "description": "TLS server name override"
        },
        "bastion": {
          "$ref": "#/$defs/SSH",
          "description": "Optional SSH bastion"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "address"
      ],
      "dependentRequired": {
        "certPath": [
          "keyPath"
        ],
        "keyPath": [
          "certPath"
        ]
      }
    }
  }
}
